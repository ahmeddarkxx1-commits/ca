{
  "name": "nexoura-core",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "npm@11.12.1",
  "scripts": {
    "dev": "npm --workspace apps/admin run dev",
    "build": "npm --workspace apps/admin run build",
    "start": "npm --workspace apps/admin run start",
    "lint": "npm --workspace apps/admin run lint",
    "format": "prettier --write .",
    "prisma:generate": "npm --workspace packages/database run prisma:generate",
    "prisma:migrate": "npm --workspace packages/database run prisma:migrate dev --name init",
    "seed": "npm --workspace packages/database run seed"
  },
  "devDependencies": {
    "@prisma/client": "^5.10.0",
    "@types/node": "^20.14.2",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.15",
    "@typescript-eslint/eslint-plugin": "^6.9.0",
    "@typescript-eslint/parser": "^6.9.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.4.0",
    "eslint-plugin-react": "^7.34.0",
    "postcss": "^8.4.0",
    "prisma": "^5.10.0",
    "prettier": "^3.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.4"
  }
}
